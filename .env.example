# Example environment configuration.
#
# The stack runs WITHOUT this file — docker-compose.yml has built-in defaults.
# Copy this to `.env` only if you want to override them:
#     cp .env.example .env   (Linux/Mac)
#     copy .env.example .env  (Windows)
#
# NOTE: DB_HOST below is set to `localhost` for LOCAL (non-Docker) development.
# Inside Docker Compose the backend automatically uses the `postgres` service
# name, so you do not need to change this for `docker compose up`.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=books_db
DB_USER=postgres
DB_PASSWORD=change_me
